# Copy to .env and fill in values. Never commit .env to git.

# MongoDB (required for Heroku – use MongoDB Atlas connection string)
MONGODB_URI=mongodb://127.0.0.1:27017/getaway

# Optional: use in production for security
JWT_SECRET=your-super-secret-jwt-key
STRIPE_SECRET_KEY=sk_test_xxxxx

# Heroku sets these automatically – do not set locally
# PORT=
# NODE_ENV=production
